{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.lib.tsbuildinfo",
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false
  },
  "include": [
    "src/index.ts",
    "src/lib/global-search/**/*.ts",
    "src/lib/global-search/**/*.tsx",
    "src/lib/utils.ts",
    "src/components/ui/**/*.ts",
    "src/components/ui/**/*.tsx"
  ]
}
